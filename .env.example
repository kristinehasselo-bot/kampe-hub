# Kopier denne filen til .env og fyll inn verdiene fra Supabase.
# Project Settings > API.
#
# Anon-nokkelen er ment a ligge i frontend. Den er trygg fordi Row Level
# Security er pa alle tabeller. Service role-nokkelen skal ALDRI inn her,
# aldri i repoet og aldri limes inn i en chat. Den hoerer kun hjemme der
# de schedulerte oppgavene kjorer.

VITE_SUPABASE_URL=https://ditt-prosjekt.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-nokkel
